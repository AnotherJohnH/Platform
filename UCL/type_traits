#pragma once

namespace std {

template<typename T>
struct type_traits
{
   constexpr static bool is_signed()         { return false; }
   constexpr static bool is_floating_point() { return false; }
};

template <> constexpr bool type_traits<signed char>     ::is_signed() { return true; }
template <> constexpr bool type_traits<signed short>    ::is_signed() { return true; }
template <> constexpr bool type_traits<signed int>      ::is_signed() { return true; }
template <> constexpr bool type_traits<signed long>     ::is_signed() { return true; }
template <> constexpr bool type_traits<signed long long>::is_signed() { return true; }
template <> constexpr bool type_traits<float>           ::is_signed() { return true; }
template <> constexpr bool type_traits<double>          ::is_signed() { return true; }

template <typename T>
inline constexpr bool is_signed_v = type_traits<T>::is_signed();

template <> constexpr bool type_traits<float> ::is_floating_point() { return true; }
template <> constexpr bool type_traits<double>::is_floating_point() { return true; }

template <typename T>
inline constexpr bool is_floating_point_v = type_traits<T>::is_floating_point();

}
